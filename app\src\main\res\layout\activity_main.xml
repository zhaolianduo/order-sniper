<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🦞 外卖抢单助手"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="20dp"
            android:gravity="center"/>

        <!-- 权限状态卡片 -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="权限状态"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tv_accessibility_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="检查中..."
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_float_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="检查中..."
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btn_open_accessibility"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="前往开启无障碍服务 →"
                    android:backgroundTint="#FF6600"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 关键词设置卡片 -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="抢单关键词"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="多个关键词用英文逗号分隔，如：东方学院,大学城,科技园"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/et_keywords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="输入关键词，多个用英文逗号分隔"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="@drawable/input_bg"
                    android:layout_marginBottom="12dp"
                    android:inputType="text"/>

                <Button
                    android:id="@+id/btn_save"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="保存关键词"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 启动悬浮窗 -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="悬浮控制窗"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="启动后会在屏幕上显示悬浮按钮，切换到外卖App后可直接控制开/关"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btn_start_float"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="启动悬浮窗"
                    android:backgroundTint="#FF6600"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 使用说明 -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="使用步骤"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1️⃣ 点击「前往开启无障碍服务」，找到「抢单助手」并开启\n\n2️⃣ 授予悬浮窗权限\n\n3️⃣ 填写关键词（如：东方学院），点保存\n\n4️⃣ 点击「启动悬浮窗」\n\n5️⃣ 切换到外卖接单App，点悬浮窗上的开关开始抢单\n\n⚠️ 命中关键词时手机会震动提示"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
